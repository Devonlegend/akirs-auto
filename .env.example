# akirs — environment template
# Copy to .env and fill in only the keys you have. Every paid source
# auto-disables when its key is missing — the pipeline works with NONE set.
#
# Full details: API_KEYS.md
# ---------------------------------------------------------------------------

# === Database / cache (defaults work for local dev) ===
DATABASE_URL=sqlite+aiosqlite:///./akirs.db
DATABASE_URL_SYNC=sqlite:///./akirs.db
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# === Facebook Ads Library scraping ===
FB_ADS_COUNTRY=Nigeria
FB_ADS_HEADLESS=false
FB_ADS_USER_DATA_DIR=.akirs-browser/facebook
FB_ADS_MAX_SCROLLS=40
FB_ADS_EMPTY_SCROLL_THRESHOLD=5
FB_ADS_SCROLL_DELAY_MS=1200

# === Keyword expansion ===
KEYWORD_CAP_DEFAULT=50
TARGET_ADS_PER_KEYWORD_DEFAULT=20
SCRAPER_KEYWORDS=restaurant, hotel, boutique, pharmacy

# === Recon — PAID sources (all optional; leave blank to disable) ===
# Hunter.io — 25 searches/mo free. https://hunter.io/users/sign_up
# HUNTER_API_KEY=

# Apollo.io — limited free tier. https://app.apollo.io/
# APOLLO_API_KEY=

# OpenCorporates — 500 calls/mo free. https://opencorporates.com/api_accounts/new
# OPENCORPORATES_API_KEY=

# TomTom — 2,500 req/day free. https://developer.tomtom.com/
# Enables verified address + phone via the `places` recon source.
# TOMTOM_API_KEY=

# People Data Labs — Company Enrichment API
# PDL_API_KEY=

# Brave Search — Web Search API
# BRAVE_SEARCH_API_KEY=

# === Recon — concurrency / rate limits ===
RECON_SEARCH_CONCURRENCY=2
RECON_SOCIAL_CONCURRENCY=1
RECON_ENRICHMENT_CONCURRENCY=2
RECON_REGISTRY_CONCURRENCY=1
RECON_WAREHOUSE_CONCURRENCY=1
RECON_PLACES_CONCURRENCY=2
RECON_SEARCH_DELAY_SECONDS=2.0

# Browser pool used by social-profile scraping
RECON_BROWSER_HEADLESS=true
RECON_BROWSER_POOL_SIZE=2

# Website scraper
RECON_WEBSITE_CONCURRENCY=2
RECON_WEBSITE_TIMEOUT_MS=15000
RECON_WEBSITE_MAX_SUBPAGES=3

# Social profile scraper
RECON_SOCIAL_TIMEOUT_MS=10000

# Per-source request budget
RECON_RATE_LIMIT_PER_MINUTE=30

# === Output ===
OUTPUT_DIR=output
